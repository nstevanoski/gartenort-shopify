eft-sm gf-elm-left-lg" data-exc=""><img src="https://ucarecdn.com/f4595d84-fc17-430b-9ed1-ebe6ec42e52a/-/format/auto/-/preview/3000x3000/-/quality/lighter/Heimwerker-Praxis.png" alt="" class="gf_image" data-gemlang="en" data-width="20%" data-height="auto" title="" width="300" height="90" natural-width="300" natural-height="90"></div></div></div></div><!--gfsplit--><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1708933387156" class="gf_row gf_row-fluid gf_row-no-padding gf_row-gap-0" data-icon="gpicon-row" data-id="1708933387156" data-layout-lg="8+4" data-extraclass="" data-layout-md="8+4" data-layout-sm="12+12" data-layout-xs="12+12" data-row-gap="0px"><div class="gf_column gf_col-lg-8 gf_col-md-8 gf_col-xs-12 gf_col-sm-12" id="c-1685509315590" data-id="1685509315590"><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387113" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387113"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h1 class="gf_gs-text-heading-2"><font color="#000000">Eine neue deutsche Erfindung sorgt bei Handwerkern für großes Aufsehen. So einfach und schnell kann Holzhacken sein!</font></h1></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387061" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387061"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><p>News: Ein neues geniales Design im Bereich der Holzbearbeitung macht das Spalten von Holz EINFACHER&nbsp; und SICHERER als je zuvor.</p></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387066" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387066"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><p><span style="color: rgb(135, 130, 130);">&nbsp;RIchard Rahner |&nbsp; Advertorial | 03. September | letztes Update vor 2 Stunden</span></p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1708933387074" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1708933387074" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/e4e01f7a-3c8e-41ba-bce4-48db9ee2907b/-/format/auto/-/preview/3000x3000/-/quality/lighter/collection%20picture.png" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1640" natural-height="924" width="1640" height="924" loading="lazy"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387025" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387025"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p><font color="#000000"><span style="font-weight: 400;">Mein Vater ist ein lebenslanger Zimmerer, der von der Verarbeitung von Brennholz lebt.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Im Laufe der Jahre übernahm er die Aufgabe der Holzverarbeitung und tat, was er konnte, um unsere Familie zu versorgen.&nbsp;</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Früher haben seine geschickten Hände und starken Arme die Axt mühelos geschwungen, und mit jedem Schwung wurde aus einem Holzscheit das perfekte Brennholz. Doch das scheint nun Vergangenheit zu sein.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Als das Alter ihn langsam einholte, wurde das Holzspalten zu einer wirklich TOLLEN Sache...</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Obwohl er es verheimlichte, konnte ich immer noch feststellen, dass er müde war und die Nerven in seinen Händen und Unterarmen drückten. Jedes Mal, wenn er versuchte, die Axt zu schwingen, wurden die Rückenschmerzen so unerträglich, dass er aufhören musste, was es ihm unmöglich machte, die Sache zu tun, auf die er einst so stolz war...</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Da stolperte ich über diesen erstaunlichen Profibohrer, den mir mein Freund Chris, ein erfahrener Bauunternehmer, empfohlen hatte und der alles einfacher machte. Und es klang fast zu schön, um wahr zu sein.</span></font></p></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387051" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387051"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h2 class="gf_gs-text-heading-2"><font color="#000000">So einfach war Holzhacken noch nie</font></h2><div></div></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1709653025325" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1709653025325" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/b4200479-0b3b-46f2-83d7-f4710fd3c996/1691056657_%E5%8A%88%E6%9C%A8%E9%92%BB%E5%A4%B4-0803-KN-01.gif" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="800" natural-height="400" width="800" height="400" loading="lazy"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387082" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387082"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p>Wenn man bedenkt, wie selten alte, uralte Werkzeuge wie Äxte zum Holzhacken eine überfällige Auffrischung erhalten, kann das unser Leben völlig verändern.</p><p><br></p><p>Also habe ich meine Bestellung aufgegeben, vor allem, um meinem Vater etwas Last von den Schultern zu nehmen.</p><p><br></p><p>Und wir waren SCHOCKIERT, als mein Vater entdeckte, dass es WIRKLICH FUNKTIONIERT - und viel SICHERER und EINFACHER ist als herkömmliche Äxte.</p><p><br></p><p>Es ist eine totale Veränderung, die ihm mindestens 4 Stunden anstrengender Arbeit erspart. Lassen Sie mich erklären...</p></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387120" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387120"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Eine Revolution beim Holzspalten, die Zeit und Mühe spart</font></h3></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1708933387060" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1708933387060" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-exc=""><img src="https://ucarecdn.com/2d7e9bdb-a716-483f-b78f-e1773a2215d4/1691057102_%E5%8A%88%E6%9C%A8%E9%92%BB%E5%A4%B4-0803-KN-06.gif" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1000" natural-height="600" width="1000" height="600" loading="lazy"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387085" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387085"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p>Einfach an einer normalen Bohrmaschine befestigt, spaltet dieser <strong>Holzspaltbohrer</strong> mühelos und in Sekundenschnelle Holz in Stücke und ähnelt damit einem leistungsstarken Holzspalter.</p><p><br></p><p>Wenn man bedenkt, wie selten veraltete Werkzeuge wie Holzspaltäxte ein dringend benötigtes Upgrade erhalten, das unser Leben revolutionieren könnte.</p><p><br></p><p>Also habe ich meine Bestellung aufgegeben, in erster Linie, um meinem Vater eine gewisse Erleichterung zu verschaffen.</p><p><strong><br></strong></p><p>Und wir waren ASTONISIERT, als mein Vater feststellte, dass diese Axt WIRKLICH FUNKTIONIERT - und dass sie viel SICHERER und EINFACHER ist als herkömmliche Äxte.</p><p><br></p><p>Es ist eine komplette Veränderung, die ihn vor mindestens 4 Stunden anstrengender Arbeit bewahrt hat.&nbsp;</p></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387076" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387076"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Verändern Sie Holzarbeiten mit diesem einzigartigen Profibohrer!</font></h3></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1708933387140" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1708933387140" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/fe7fde2b-226e-4a80-b503-0ac61b7e3c2c/ezgif.com-optimize%20_2_.gif" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="600" natural-height="316" width="600" height="316" loading="lazy"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387171" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387171"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p><strong><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);">Eine hochmoderne Alternative zur herkömmlichen Axt in der Holzbearbeitung!</span><br></strong></p><p><br></p><p>Diese innovative Lösung fasst die Leistung eines elektrischen Hochleistungs-Holzspalters in einem kompakten Bohreraufsatz zusammen, der dennoch eine enorme Stärke aufweist. Er lässt sich innerhalb von Sekunden mühelos an jeder Bohrmaschine befestigen.</p><p><br></p><p>Das bahnbrechende Design macht die manuelle Anstrengung überflüssig, die normalerweise mit dem Hacken von dickem Holz verbunden ist. Außerdem ist es nicht nur sicherer, sondern auch bequemer und schneller!</p><p><br></p><p><strong>Die Axt ist aus kohlenstoffreichem Industriestahl gefertigt und zeichnet sich durch ihre Robustheit, Rostbeständigkeit und Korrosionsbeständigkeit bei geringem Gewicht aus.</strong></p><p><br></p><p>Im Vergleich zu herkömmlichen Äxten ist sie 5 Mal effizienter beim Holzhacken und verwandelt Stämme mit einem Durchmesser von 7" mühelos in perfekte Stücke. In nur 30 Sekunden ist eine ganze Ladung fertig!</p><p><br></p><p>Verabschieden Sie sich von Rückenschmerzen und körperlicher Anstrengung - holen Sie sich jetzt Ihre Axt und machen Sie das Holzspalten zu einem Kinderspiel!</p></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387093" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387093"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Wieso Tausende Personen diesen Profibohrer verwenden?</font></h3></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1708933387139" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1708933387139" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-left-lg" data-exc=""><img src="https://ucarecdn.com/9bef365a-8fdd-4f96-b490-b4a64bf00727/ezgif.com-optimize%20_4_.gif" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="600" natural-height="316" width="600" height="316" loading="lazy"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387112" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387112"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);"><strong>Sein ausgeklügeltes Design macht ihn zum ultimativen Mittel zum Holzspalten.</strong></span><br></p><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);"><br></span></p><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);">Je tiefer das Gewinde des Bohrers ist, desto müheloser und effizienter wird das Holzhacken, denn er verfügt über ein revolutionäres Spitzgewinde und eine rutschfeste Rille.</span></p><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);"><br></span></p><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);">Stellen Sie sich vor, Sie haben ein Superwerkzeug in der Hand, das mit jeder Drehung mühelos in das Holz eindringt und Ihnen die Genugtuung eines perfekt gehackten Brennholzes bei geringstem Kraftaufwand bietet.</span></p><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);"><br></span></p><p><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px; background-color: var(--color-body); font-style: var(--font-style-body);"><strong>Das Besondere an diesem Gerät ist seine universelle Kompatibilität - es lässt sich nahtlos an ALLE Bohrmaschinen, Elektrohämmer, Elektroschrauber und Schlagbohrmaschinen anschließen, unabhängig von Marke und Größe.</strong></span></p><p><br></p><p>Die kompakte Größe und das geringe Gewicht sind weitere Merkmale, die ich sehr schätze. Jetzt können Sie innerhalb von Minuten sicher Holz spalten, ob an Ihrem Arbeitsplatz, beim Camping, auf dem Bauernhof oder im Garten - wo auch immer Sie sich befinden.</p></div></div><div data-label="Button" data-key="button" data-atomgroup="element" id="e-1708933387086" class="element-wrap" data-icon="gpicon-gpicon-button" data-ver="1.0" data-id="1708933387086"><div class="elm gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-stretch-lg="0" data-stretch-md="0" data-stretch-sm="0" data-stretch-xs="0"><a class="button btn gf_button gf_gs-button-element gf_gs-button---large" href="https://rtrk.gartenpfad.com/click" target="" data-scroll-speed="2000" data-exc="" data-scroll-speed-md="2000" data-scroll-speed-sm="2000" data-scroll-speed-xs="2000" aria-describedby="a11y-external-message"><span>Verfügbarkeit prüfen 👉</span></a></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387163" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387163"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Einfachheit für alle - vom Bauunternehmer bis zum Hausbesitzer!</font></h3></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1708933387099" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1708933387099" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-left-lg" data-exc=""><img src="https://ucarecdn.com/3d34f4d9-ad7f-4ec9-8ae6-6f79dcb3e680/-/format/auto/-/preview/3000x3000/-/quality/lighter/Your%20paragraph%20text.png" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1520" natural-height="800" width="1520" height="800" loading="lazy"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387168" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387168"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p>Bauunternehmer und Holzfäller werden den Holzspaltbohrer sicher zu schätzen wissen, aber seine Vielseitigkeit geht weit darüber hinaus. Er wird immer mehr zu einer bevorzugten Lösung für Heimwerker, Camper, Hausbesitzer und sogar Baumpfleger, die ihn bereits in den höchsten Tönen loben.</p><p><br></p><p>Für meinen Vater hat sich dieses Werkzeug als wahrer Glücksgriff erwiesen, denn es hat einen riesigen Holzstapel in weniger als 30 Minuten in perfekt geschnittene Stücke verwandelt - und das ganz ohne Schweißausbrüche!</p><p><br></p><p>Ein stolzes Lächeln zierte das Gesicht meines Vaters, als er den sauber gespaltenen Brennholzstapel betrachtete.</p><p><br></p><p>Es ist erstaunlich, wie ein so kompaktes Gerät einen so großen Unterschied in der Holzspalterei meines Vaters ausmachen kann.</p><p><br></p><p>Zu sehen, wie er mit neuem Elan an die Arbeit geht, bereitet mir große Freude.</p></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1708933387080" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1708933387080"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Absolut, ohne jeden Zweifel, JA!</font></h3></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387058" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1708933387058"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><p>Wenn Sie der anstrengenden Arbeit und der Verletzungsgefahr, die mit traditionellen Äxten verbunden sind, überdrüssig sind, oder wenn Sie einfach nur Brennholz für Ihren Grill sammeln wollen...</p><p><br></p><p>Dies ist das ultimative Werkzeug, das ausnahmslos jede Aufgabe beim Holzspalten mühelos bewältigt!</p><p><br></p><p>Stellen Sie sich vor, mehr Zeit am Lagerfeuer oder mit Ihren Liebsten zu verbringen.</p><p><br></p><p>Und das alles ohne die Gefahr von Schnittwunden oder Verletzungen!</p><p><br></p><p>Und was noch besser ist: Sie sparen nicht nur kostbare Zeit, indem Sie mühelos Holz spalten, sondern seine robuste Konstruktion sorgt dafür, dass es über Jahre hinweg ein zuverlässiger Begleiter bleibt.</p></div></div><div data-label="Button" data-key="button" data-atomgroup="element" id="e-1708933387165" class="element-wrap" data-icon="gpicon-gpicon-button" data-ver="1.0" data-id="1708933387165"><div class="elm gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-stretch-lg="0" data-stretch-md="0" data-stretch-sm="0" data-stretch-xs="0"><a class="button btn gf_button gf_gs-button-element gf_gs-button---large" href="https://rtrk.gartenpfad.com/click" target="" data-scroll-speed="2000" data-exc="" data-scroll-speed-md="2000" data-scroll-speed-sm="2000" data-scroll-speed-xs="2000" aria-describedby="a11y-external-message"><span>Jetzt Rabatt und Verfügbarkeit prüfen ➡️</span></a></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1708933387097" class="gf_row gf_equal-height gf_row-gap-10" data-icon="gpicon-row" data-id="1708933387097" data-layout-lg="12" data-extraclass="" data-layout-md="12" data-layout-sm="12" data-layout-xs="12" style="display: flex; flex-wrap: wrap; visibility: visible;" data-row-gap="10px"><div class="gf_column gf_col-lg-12 gf_col-md-12 gf_col-sm-12 gf_col-xs-12" id="c-1685516813895" data-id="1685516813895" style="display: block; flex-direction: unset; justify-content: unset; min-height: auto;"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1708933387135" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id=