    "gp_section_604256710307218095": {
      "settings": {
        "checksum": "7bb2a53dfb8a6be400bbf812d17b6720049f2e8bb4cdfec9abb454dbe762e486_1_1_0_0__1",
        "ggtVVusgsuT_text": "<span style=\"font-size:47px;\"><i><strong>Lebenswerk-Journal</strong></i></span>",
