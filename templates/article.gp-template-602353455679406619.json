    "gp_section_602353455780200987": {
      "settings": {
        "checksum": "c5d5cf7e3a0a0d3a258e8d85adb39c0f190bd3622a6ea768fc7af813678fe8a4_1_1_0_0__1",
        "ggZUIxPUjdK_text": "<span style=\"font-size:47px;\"><i><strong>Lebenswerk-Journal</strong></i></span>",
        "section_preload": "true"
