        "ggf1qmWqway_childItem_0": "<p><span style=\"color:#000000;\">Faszinierendes Mondlicht-Erlebnis</span></p>",
        "ggf1qmWqway_childItem_1": "<p>Ein Hauch von Küstenromantik</p>",
