        "checksum": "3c136f2d2a3e41ea539390bb58cbbef771ced53d7bc1abebd2cbb701cbd2dd38_1_1_0_0__1",
        "ggMDZPILWVI_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0815/6889/1219/files/Heimundgarten-Journal_4ba1ea53-fe02-4296-a975-1c2b7218b260.png?v=1771266175"
