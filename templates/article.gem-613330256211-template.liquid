          {% form 'new_comment', article %}            {%- assign formId = 'CommentForm' -%}            <h2 class="h3">{{ 'blogs.comments.title' | t }}</h2>            {%- assign post_message = 'blogs.comments.success' -%}
            {%- if blog.moderated? and comment.status == 'pending' -%}
              {%- assign post_message = 'blogs.comments.success_moderated' -%}
            {%- elsif comment.status == 'unapproved' or comment.status == 'spam' -%}
              {%- assign post_message = 'blogs.comments.unapproved' -%}
            {%- endif -%}            {% include 'form-status', form: form, form_id: formId, success_message: post_message %}            <div class="grid">              <div class="grid__item medium-up--one-half">
                <label for="{{ formId }}-author">{{ 'blogs.comments.name' | t }}</label>
