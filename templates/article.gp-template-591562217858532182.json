        "ggf1qmWqway_childItem_1": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(18,18,18);font-size:16px;\"><strong>Jedes Stück erzählt eine Geschichte der Erneuerung</strong></span></p>",
