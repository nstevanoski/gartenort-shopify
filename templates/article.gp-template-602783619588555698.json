    "gp_section_602783619672507314": {
      "settings": {
        "checksum": "ff9e5faa8135efbf96d58c212c56d566a1577db25f869a8590f67e5cdf113a6d_1_1_0_0__1",
        "ggZUIxPUjdK_text": "<span style=\"font-size:47px;\"><i><strong>Lebenswerk-Journal</strong></i></span>",
