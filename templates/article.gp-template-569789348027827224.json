        "ggMqZR3jAut_label": "<p><span style=\"color:#EFEFEF;font-size:21px;\"><strong>Verfügbarkeit prüfen 👉</strong></span></p><p>&nbsp;</p><p>&nbsp;</p><p>&nbsp;</p><p>&nbsp;</p>"
