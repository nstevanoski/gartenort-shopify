    "gp_section_602785148211102682": {
      "settings": {
        "checksum": "16b7475269035992e16ee08b6c6d6d4ddbee255d6bdf382d8228c9b22512260e_1_1_0_0__1",
        "ggZUIxPUjdK_text": "<span style=\"font-size:47px;\"><i><strong>Lebenswerk-Journal</strong></i></span>",
