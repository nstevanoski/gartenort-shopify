mat/auto/-/preview/120x120/-/quality/lighter/3.png" alt="" class="gf_image gf_lazyload" data-gemlang="en" data-width="30%" data-height="auto" title="" width="300" height="90" natural-width="300" natural-height="90" data-lg-size="3000x3000"></div></div></div></div><!--gfsplit--><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1709026996382" class="gf_row gf_row-fluid gf_row-no-padding gf_row-gap-0" data-icon="gpicon-row" data-id="1709026996382" data-layout-lg="8+4" data-extraclass="" data-layout-md="8+4" data-layout-sm="12+12" data-layout-xs="12+12" data-row-gap="0px"><div class="gf_column gf_col-lg-8 gf_col-md-8 gf_col-xs-12 gf_col-sm-12" id="c-1685509315590" data-id="1685509315590"><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1709026996356" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1709026996356"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h1 class="gf_gs-text-heading-2"><font color="#000000">Das perfekte Geschenk für Träumer – handgemacht, leuchtend und voller Wärme</font></h1></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1709026996419" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1709026996419"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><p><font color="#878282">Konrad Kronenberg | Publiziert vor 2 Stunden</font></p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1709562165566" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1709562165566" data-resolution="3000x3000" style=""><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/3c1e6a1f-b584-4d5c-9212-005bd1e04dbb/-/format/auto/-/preview/120x120/-/quality/lighter/5.jpg" alt="" class="gf_image gf_lazyload" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1000" natural-height="600" width="1000" height="600" loading="lazy" data-lg-size="3000x3000"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1709026996388" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1709026996388"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-lg gf-elm-left-xs" data-gemlang="en" data-exc=""><p><font color="#000000" style="font-weight: normal;">Ich hatte an diesem Abend nichts Besonderes erwartet.</font></p><p><font color="#000000" style="font-weight: normal;"><br></font></p><p><font color="#000000" style="font-weight: normal;">Nur ein einfaches Abendessen, vielleicht ein paar ruhige Minuten zum Abschalten nach einer langen Woche.</font></p><p><font color="#000000" style="font-weight: normal;"><br></font></p><p><font color="#000000" style="font-weight: normal;">Als meine Schwester mit einem kleinen, wunderschön verpackten Geschenk vor der Tür stand, musste ich lächeln und sagte:</font></p><p><font color="#000000" style="font-weight: normal;">„Wirklich, du hättest das nicht tun müssen. Ich habe doch alles, was ich brauche.“</font></p><p><font color="#000000" style="font-weight: normal;"><br></font></p><p><font color="#000000" style="font-weight: normal;">Aber in dem Moment, als ich das Band löste und den Deckel anhob, wurde es still.</font></p><p><font color="#000000" style="font-weight: normal;"><br></font></p><p><font color="#000000" style="font-weight: normal;">Darin lag eine Tasse – aber nicht irgendeine.</font></p><p><font color="#000000" style="font-weight: normal;"><br></font></p><p><font color="#000000" style="font-weight: normal;">Auf den ersten Blick sah sie fast magisch aus.</font></p><p><font color="#000000" style="font-weight: normal;">Ihre Oberfläche schimmerte sanft, die Farben flossen wie im Tanz ineinander –</font></p><p><font color="#000000" style="font-weight: normal;">warmes Gold verschmolz mit zartem Rosa, orangene Töne gingen in tiefes Violett über.</font></p><p><font color="#000000" style="font-weight: normal;"><br></font></p><p><font color="#000000" style="font-weight: normal;">Und als das Licht sie traf, begann sie zu leuchten.</font></p><p><font color="#000000" style="font-weight: normal;">Für einen Moment hatte ich das Gefühl, einen Sonnenuntergang in den Händen zu halten.</font></p><p><span style="color: rgb(0, 0, 0);"></span></p><p><span style="color: rgb(0, 0, 0);"></span></p><p><span style="color: rgb(0, 0, 0);"></span></p><p><span style="color: rgb(0, 0, 0);"></span></p><p><font color="#000000"></font></p><p><font color="#000000"></font></p><p><font color="#000000"></font></p><p><font color="#000000"></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1714045396277" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1714045396277" data-resolution="3000x3000" style=""><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://cdn.shopify.com/s/files/1/0815/6889/1219/files/Generating_Video_of_Mug-ezgif.com-gif-to-webp-converter_120x120.webp?v=1762972087" alt="" class="gf_image gf_lazyload" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="672" natural-height="405" width="672" height="405" loading="lazy" data-lg-size="3000x3000"></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1751954958090" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1751954958090" style=""><div class="elm text-edit gf-elm-center gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Eine Tasse, die Ruhe und Schönheit einfängt</font></h3></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1713946259430" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1713946259430"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-lg gf-elm-left-xs" data-gemlang="en" data-exc=""><p><font color="#000000"><span style="font-weight: 400;">Ich drehte sie langsam in meinen Händen – und mit jeder Bewegung veränderten sich die Farben,</span></font></p><p><font color="#000000"><span style="font-weight: 400;">als wäre der Himmel selbst auf das Porzellan gemalt.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Etwas daran hatte eine fast meditative Wirkung.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Draußen ging der Tag weiter, Autos fuhren vorbei, das Handy vibrierte –</span></font></p><p><font color="#000000"><span style="font-weight: 400;">doch in diesem Moment war alles still.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Sie erinnerte mich an all die Abende auf dem Balkon,</span></font></p><p><font color="#000000"><span style="font-weight: 400;">wenn die Sonne langsam hinter dem Horizont verschwand</span></font></p><p><font color="#000000"><span style="font-weight: 400;">und die Welt für ein paar Minuten ganz friedlich war.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Es ist erstaunlich, wie ein einzelner Gegenstand dieses Gefühl zurückbringen kann –</span></font></p><p><font color="#000000"><span style="font-weight: 400;">wie ein Stück Schönheit die Zeit anhalten kann, wenn auch nur kurz.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Diese Tasse tat genau das.</span></font></p><p><font color="#000000"><span style="font-weight: 400;"><br></span></font></p><p><font color="#000000"><span style="font-weight: 400;">Sie war mehr als nur ein Trinkgefäß – sie war ein Moment des Innehaltens.</span></font></p><p><font color="#000000"><span style="font-weight: 400;">Ein kleiner Zauber für den Alltag.</span></font></p><p><span style="color: rgb(0, 0, 0); font-weight: 400;"></span></p><p><span style="color: rgb(0, 0, 0); font-weight: 400;"></span></p><p><span style="color: rgb(0, 0, 0); font-weight: 400;"></span></p><p><span style="color: rgb(0, 0, 0); font-weight: 400;"></span></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p><p><font color="#000000"><span style="font-weight: 400;"></span></font></p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1751954804790" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1751954804790" data-resolution="3000x3000" style=""><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/5d0eb190-4d46-4d7e-8d0b-2d106e30388b/-/format/auto/-/preview/120x120/-/quality/lighter/2.jpg" alt="" class="gf_image gf_lazyload" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1000" natural-height="600" width="1000" height="600" loading="lazy" data-lg-size="3000x3000"></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1762971352473" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1762971352473" style=""><div class="elm text-edit gf-elm-center gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Die Geschichte hinter dem Sonnenkuss</font></h3></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1709026996416" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1709026996416" style=""><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-lg gf-elm-left-xs" data-gemlang="en" data-exc=""><p>Später erzählte mir meine Schwester mehr darüber.</p><p><br></p><p>Sie heißt Sonnenkuss – Handgemachte Tasse im Farbspiel des Sonnenuntergangs.</p><p><br></p><p>Ein Name, der nicht treffender sein könnte.</p><p><br></p><p>Jede einzelne Tasse wird von erfahrenen Kunsthandwerkern von Hand gefertigt.</p><p>Keine gleicht der anderen – jede ist ein Unikat.</p><p><br></p><p>Die Herstellung ist aufwendig:</p><p>Mehrere Schichten Glasur werden per Hand aufgetragen,</p><p>anschließend bei exakt abgestimmter Temperatur gebrannt,</p><p>damit sich das sanfte Farbenspiel entfalten kann –</p><p>wie das Licht, das sich am Himmel im Abendrot verändert.</p><p><br></p><p>Im Morgenlicht leuchtet sie golden und weich,</p><p>am Abend entfalten sich tiefviolette Nuancen.</p><p><br></p><p>So trägt jede Tasse ihr eigenes Licht, ihren eigenen Moment in sich.</p><p><br></p><p>Das ist es, was sie so besonders macht:</p><p>Sie ist nicht nur ein Stück Keramik –</p><p>sie ist Handwerkskunst mit Seele, inspiriert vom schönsten Moment des Tages.</p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1719232820743" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1719232820743" data-resolution="3000x3000" style=""><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/989027c2-4eba-4f5a-aacd-237debff296c/-/format/auto/-/preview/120x120/-/quality/lighter/3.jpg" alt="" class="gf_image gf_lazyload" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1000" natural-height="600" width="1000" height="600" loading="lazy" data-lg-size="3000x3000"></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1762971378961" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1762971378961" style=""><div class="elm text-edit gf-elm-center gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">So schön wie praktisch</font></h3></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1719233264427" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1719233264427" style=""><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-lg gf-elm-left-xs" data-gemlang="en" data-exc=""><p>Trotz ihrer künstlerischen Schönheit ist der Sonnenkuss für den Alltag gemacht.</p><p><br></p><p>Mit einem Fassungsvermögen von 330 ml (11 oz) ist sie ideal für Kaffee, Tee oder heiße Schokolade.</p><p>Die hochwertige Keramik hält Getränke angenehm warm,</p><p>während die glatte Glasur wunderbar in der Hand liegt.</p><p><br></p><p>Und das Beste:</p><p>Die Tasse ist <strong>spülmaschinen- und mikrowellengeeignet –</strong></p><p>praktisch, robust und für den täglichen Gebrauch gemacht.</p><p><br></p><p>Hier trifft Ästhetik auf Funktion.</p><p>Ein Stück Handwerkskunst, das nicht im Regal verstauben soll,</p><p>sondern deinen Alltag verschönert –</p><p>jeden Morgen, jeden Abend, immer dann, wenn du einen Moment Ruhe brauchst.</p><p><strong></strong></p><p><strong></strong></p><p><strong></strong></p><p><strong></strong></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1751954914145" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1751954914145" data-resolution="3000x3000" style=""><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/5e185d6a-ea32-4cd1-84c7-1ed914b0076c/-/format/auto/-/preview/120x120/-/quality/lighter/1747889202_9.jpg" alt="" class="gf_image gf_lazyload" data-gemlang="en" data-width="100%" data-height="auto" title="" natural-width="1000" natural-height="600" width="1000" height="600" loading="lazy" data-lg-size="3000x3000"></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1762971402761" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1762971402761" style=""><div class="elm text-edit gf-elm-center gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf-elm-left-lg" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Ein Geschenk mit Bedeutung</font></h3></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1751954939504" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1751954939504" style=""><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-left-md gf-elm-left-sm gf-elm-left-lg gf-elm-left-xs" data-gemlang="en" data-exc=""><p>Als ich wieder zu meiner Schwester aufsah, lächelte sie.</p><p><br></p><p>„Ich weiß, wie sehr du Sonnenuntergänge liebst,“ sagte sie leise.</p><p>„Ich wollte, dass du immer ein kleines Stück davon bei dir hast.“</p><p><br></p><p>Da verstand ich, was dieses Geschenk so besonders machte.</p><p><br></p><p>Es war nicht nur die Handarbeit oder das Farbenspiel –</p><p>es war das Gefühl dahinter.</p><p><br></p><p>Ein Gefühl von Wärme, Ruhe und Erinnerung.</p><p>Jedes Mal, wenn ich sie benutze, denke ich an diesen Moment –</p><p>und daran, wie schön es ist, kleine Dinge mit Bedeutung zu besitzen.</p><p></p><p></p><p></p><p></p><p></p><p></p><p><strong></strong></p><p><strong></strong></p><p><strong></strong></p><p><strong></strong></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p></div></div><div data-label="Button" data-key="button" data-atomgroup="element" id="e-1709026996375" class="element-wrap" data-icon="gpicon-gpicon-button" data-ver="1.0" data-id="1709026996375"><div class="elm gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-stretch-lg="0" data-stretch-md="0" data-stretch-sm="0" data-stretch-xs="0"><a class="button btn gf_button gf_gs-button-element gf_gs-button---large" href="https://rtrk.gartenpfad.com/click" target="" data-scroll-speed="2000" data-exc="" data-scroll-speed-md="2000" data-scroll-speed-sm="2000" data-scroll-speed-xs="2000" aria-describedby="a11y-external-message"><span>Verfügbarkeit prüfen 👉</span></a></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1709026996325" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1709026996325"><div class="elm text-edit gf-elm-center gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-gemlang="en" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#000000">Begeistert in ganz Europa</font></h3></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1709275370894" class="gf_row gf_equal-height" data-icon="gpicon-row" data-id="1709275370894" data-layout-lg="6+6" data-extraclass="" data-layout-md="6+6" data-layout-sm="6+6" data-layout-xs="12+12" style="display: flex; flex-wrap: wrap; visibility: visible;"><div class="gf_column gf_col-lg-6 gf_col-md-6 gf_col-sm-6 gf_col-xs-12" id="c-1709275370944" data-id="1709275370944" style="display: flex; flex-direction: column; justify-content: center; min-height: auto;"><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1709275382266" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1709275382266" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/48c49b6e-5de7-49f7-8c8e-ad379fdac64d/-/format/auto/-/preview/120x120/-/quality/lighter/a86585ea-a154-459d-aca5-dc7e8e611e20.png" alt="" class="gf_image gf_lazyload" data-gemlang="en" width="1024" height="1024" data-width="100%" data-height="auto" title="" natural-width="1024" natural-height="1024" data-lg-size="3000x3000" loading="lazy"></div></div></div><div class="gf_column gf_col-lg-6 gf_col-md-6 gf_col-sm-6 gf_col-xs-12" id="c-1709275372314" data-id="1709275372314" style="display: flex; flex-direction: column; justify-content: center; min-height: auto;"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1709275378713" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1709275378713" style=""><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-gemlang="en" data-exc=""><p>⭐⭐⭐⭐⭐</p><p><br></p><p><strong style="color: rgb(0, 0, 0);">„Ein Stück Sonnenuntergang in meinen Händen“</strong></p><p><span style="color: rgb(0, 0, 0);">Die Farben verändern sich je nach Licht – einfach faszinierend. Jede Tasse ist anders und wunderschön.</span></p><p><span style="color: rgb(0, 0, 0);"><br></span></p><p><span style="font-weight: bold; color: rgb(0, 0, 0);">— Ursula K., 40, Berlin</span></p></div></div></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1709275493729" class="gf_row gf_equal-height" data-icon="gpicon-row" data-id="1709275493729" data-layout-lg="6+6" data-extraclass="" data-layout-md="6+6" data-layout-sm="6+6" data-layout-xs="12+12" style="display: flex; flex-wrap: wrap; visibility: visible;"><div class="gf_column gf_col-lg-6 gf_col-md-6 gf_col-sm-6 gf_col-xs-12" id="c-1709275370944" data-id="1709275370944" style="display: flex; flex-direction: column; justify-content: center; min-height: auto;"><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1709275493852" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1709275493852" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/288f5976-740a-4c51-9ba4-769f9f43ff95/-/format/auto/-/preview/120x120/-/quality/lighter/b41d9b57-a5c8-476e-821a-99623c83806c.png" alt="" class="gf_image gf_lazyload" data-gemlang="en" width="1024" height="1024" data-width="100%" data-height="auto" title="" natural-width="1024" natural-height="1024" data-lg-size="3000x3000" loading="lazy"></div></div></div><div class="gf_column gf_col-lg-6 gf_col-md-6 gf_col-sm-6 gf_col-xs-12" id="c-1709275372314" data-id="1709275372314" style="display: flex; flex-direction: column; justify-content: center; min-height: auto;"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1709275493781" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1709275493781" style=""><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-gemlang="en" data-exc=""><p>⭐⭐⭐⭐⭐</p><p><br></p><p><span style="font-weight: bold; color: rgb(0, 0, 0);">„Mein täglicher Begleiter“</span></p><p><span style="color: rgb(0, 0, 0);"><br></span></p><p><span style="color: rgb(0, 0, 0);">Ich trinke morgens meinen Kaffee und abends Tee daraus. Sie macht jeden Moment ein bisschen besonderer.</span></p><p><span style="font-weight: bold; color: rgb(0, 0, 0);">— Thomas M., 52, Köln</span></p></div></div></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1709275498296" class="gf_row gf_equal-height" data-icon="gpicon-row" data-id="1709275498296" data-layout-lg="6+6" data-extraclass="" data-layout-md="6+6" data-layout-sm="6+6" data-layout-xs="12+12" style="display: flex; flex-wrap: wrap; visibility: visible;"><div class="gf_column gf_col-lg-6 gf_col-md-6 gf_col-sm-6 gf_col-xs-12" id="c-1709275370944" data-id="1709275370944" style="display: flex; flex-direction: column; justify-content: center; min-height: auto;"><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1709275498217" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1709275498217" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://cdn.shopify.com/s/files/1/0815/6889/1219/files/Sonnenkuss_1_120x120.jpg?v=1762962311" alt="" class="gf_image gf_lazyload" data-gemlang="en" width="1080" height="1080" data-width="100%" data-height="auto" title="" natural-width="1080" natural-height="1080" data-lg-size="3000x3000" loading="lazy"></div></div></div><div class="gf_column gf_col-lg-6 gf_col-md-6 gf_col-sm-6 gf_col-xs-12" id="c-1709275372314" data-id="1709275372314" style="display: flex; flex-direction: column; justify-content: center; min-height: auto;"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1709275498338" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1709275498338" style=""><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-gemlang="en" data-exc=""><p>⭐⭐⭐⭐⭐</p><p><span style="color: rgb(0, 0, 0);"><br></span></p><p><span style="font-weight: bold; color: rgb(0, 0, 0);">„Ein Geschenk mit Seele“</span></p><p><span style="color: rgb(0, 0, 0);"><br></span></p><p><span style="color: rgb(0, 0, 0);">Ich habe sie meiner Mutter geschenkt, sie war gerührt. Sie sagt, es erinnert sie an unsere Sommerabende.</span></p><p><span style="color: rgb(0, 0, 0);"><br></span></p><p><span style="font-weight: bold; color: rgb(0, 0, 0);">— Jens B., 61, Bremen</span></p><p><br></p></div></div></div><